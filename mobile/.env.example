# URL racine du backend Coherence consomme par l'app (POST {EXPO_PUBLIC_API_URL}/analyze).
# Variable PUBLIQUE Expo (prefixe EXPO_PUBLIC_) : embarquee au bundle, donc JAMAIS
# de secret ici (aucune cle OpenAI/Google/admin cote app). Definissez-la pour que
# analyzeListing pointe vers un backend ; sans elle, getApiUrl() renvoie "" et
# l'appel echoue.
#
# Exemples (ne PAS commiter de vraie URL dans .env, qui est gitignore) :
#   staging : EXPO_PUBLIC_API_URL=https://coherence-staging.fly.dev
#   local   : EXPO_PUBLIC_API_URL=http://<ip-lan>:8080
EXPO_PUBLIC_API_URL=
