{
  "expo": {
    "name": "Cohérence",
    "slug": "coherence",
    "scheme": "coherence",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1EA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "fr.coherencemetz.app"
    },
    "android": {
      "package": "fr.coherencemetz.app",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1EA"
      }
    }
  }
}
