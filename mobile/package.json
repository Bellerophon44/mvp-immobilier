{
  "name": "mvp-immobilier-mobile",
  "private": true,
  "version": "0.0.1",
  "main": "expo/AppEntry.js",
  "description": "App mobile (Phase 2) — boucle partage/collage -> extraction WebView -> /analyze -> resultat, par-dessus le coeur de logique pure de src/lib.",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "update:preview": "eas update --branch preview --environment preview",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:ios:prod": "eas build -p ios --profile production",
    "submit:ios": "eas submit -p ios --latest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/geist-mono": "^0.4.2",
    "@expo-google-fonts/instrument-serif": "^0.4.1",
    "expo": "~54.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-sqlite": "~16.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-webview": "^13.15.0"
  }
